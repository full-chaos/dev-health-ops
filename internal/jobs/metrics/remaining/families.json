      "parity_state": "partial_numerical_oracle"
    },
    {
      "name": "recommendations",
      "python_sources": ["src/dev_health_ops/workers/recommendations_tasks.py", "src/dev_health_ops/recommendations/engine.py"],
      "writes": ["recommendations_daily"],
      "profile": "heavy",
      "max_concurrency": 2,
      "clickhouse_read_budget": 2,
      "clickhouse_write_budget": 1,
      "replay": "append_latest_generation",
      "route_key": "metrics.remaining.recommendations",
      "route": "celery",
      "rollback_route": "celery",
      "historical_limitation": "Evaluation only reads finalized persisted daily metric partitions and preserves explicit non-fired tombstones.",
      "parity_state": "inventory_only"
    },
    {
      "name": "extra_metrics",
      "python_sources": ["src/dev_health_ops/metrics/job_compounding_risk.py", "src/dev_health_ops/metrics/compute_testops_risk.py", "src/dev_health_ops/metrics/benchmarking/runner.py"],

    "BatchEnvelope": {
      "additionalProperties": false,
      "properties": {
        "idempotencyKey": {
          "maxLength": 255,
          "minLength": 1,
          "title": "Idempotencykey",
          "type": "string"
        },
        "records": {
          "items": {
            "$ref": "#/$defs/RecordEnvelope"
          },
          "minItems": 1,
          "title": "Records",
          "type": "array"
        },
        "schemaVersion": {
          "const": "external-ingest.v1",
          "title": "Schemaversion",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/SourceDescriptor"
        },
        "window": {
          "anyOf": [
            {
              "$ref": "#/$defs/IngestWindow"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "schemaVersion",
        "idempotencyKey",
        "source",
        "records"
      ],
      "title": "BatchEnvelope",
      "type": "object"
    },

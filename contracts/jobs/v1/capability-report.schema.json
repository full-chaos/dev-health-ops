{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.fullchaos.dev/jobs/v1/capability-report.schema.json",
  "title": "Dev Health worker contract capability report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "contracts"],
  "properties": {
    "schema_version": {"const": 1},
    "profile": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "versions", "schema_digests"],
        "properties": {
          "kind": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"},
          "versions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
          "schema_digests": {
            "type": "object",
            "minProperties": 1,
            "patternProperties": {
              "^[1-9][0-9]*$": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
            },
            "additionalProperties": false
          }
        }
      }
    }
  }
}

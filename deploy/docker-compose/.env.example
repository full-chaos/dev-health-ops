DEV_HEALTH_IMAGE=ghcr.io/your-org/dev-health-ops:latest

CLICKHOUSE_USER=ch
CLICKHOUSE_PASSWORD=ch
CLICKHOUSE_DB=default
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

POSTGRES_HOST=postgres.example.com
POSTGRES_USER=devhealth
POSTGRES_PASSWORD=devhealth
POSTGRES_DB=devhealth
POSTGRES_URI=postgresql+asyncpg://devhealth:devhealth@postgres.example.com:5432/devhealth
PGBOUNCER_TRANSACTION_MODE=false

REDIS_PORT=6379

API_PORT=8000
BILLING_EDGE_PORT=8010
GRAPHQL_QUERY_TIMEOUT=30
LOG_LEVEL=INFO

WORKER_CONCURRENCY=4
WORKER_HEAVY_CONCURRENCY=2
WORKER_STOP_GRACE_PERIOD=3700s

# Sync dispatcher / worker routing. The production compose worker -Q lists
# include these queues, so these defaults are safe to enable.
PROVIDER_SYNC_QUEUES_ENABLED=true
SYNC_COST_CLASS_QUEUES=true
HIDE_MIGRATED_CHILD_CONFIGS=true

# Sync dispatch safety caps and stale windows.
SYNC_RUN_MAX_UNITS=1000
SYNC_UNIT_CONCURRENCY_PER_BUCKET=8
SYNC_UNIT_DISPATCH_STALE_SECONDS=900
SYNC_UNIT_RUNNING_STALE_SECONDS=3600
SYNC_DISPATCH_REDISPATCH_COUNTDOWN=60
SYNC_OUTBOX_CLAIM_TIMEOUT_SECONDS=300
SYNC_WATERMARK_OVERLAP=0

# GitHub sync budget guard. Values are abstract reservation units, not raw
# GitHub requests. Setting SYNC_BUDGET_BUCKET_LIMITS enables enforcement.
SYNC_BUDGET_BUCKET_LIMITS='{"github:rest_core":250,"github:graphql_cost":500,"github:contents_blob":100,"github:secondary_abuse_risk":25}'
SYNC_BUDGET_DEFAULT_LIMIT=1000000
SYNC_BUDGET_DEFERRAL_SECONDS=60
SYNC_BUDGET_DEFERRAL_JITTER_SECONDS=5
# SYNC_BUDGET_DRY_RUN_BUCKET_LIMITS='{"github:rest_core":250,"github:graphql_cost":500,"github:contents_blob":100,"github:secondary_abuse_risk":25}'
SYNC_BUDGET_DRY_RUN_DEFAULT_LIMIT=1000000
SYNC_BUDGET_DRY_RUN_DEFERRAL_SECONDS=60

GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_BASE_URL=https://api.github.com
GITHUB_LINEAR_LINKBACK_BOTS=linear[bot]
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=

LINEAR_API_KEY=
LINEAR_TRUSTED_SCM_HOSTS=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_TEAM=
STRIPE_PRICE_ID_ENTERPRISE=
LICENSE_PRIVATE_KEY=
